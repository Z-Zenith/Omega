{
  "name": "@campus/direct-messaging",
  "version": "0.1.0",
  "private": true,
  "description": "Direct Messaging (DMS) — one-to-one student-teacher messaging component consumed by the Student Desktop App (SDA-24) and Teacher Web App (TWA-18). See docs/Campus platform architecture.md Section 3 (DMS-01).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc",
    "build": "tsc -p tsconfig.base.json",
    "build:host": "node scripts/build-host.mjs",
    "pretest": "npm run build",
    "test": "tsc && node --test"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "campus-platform",
    "dms",
    "direct-messaging",
    "twa",
    "sda"
  ],
  "license": "UNLICENSED",
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
