<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StudentDesktop.ViewModels"
             xmlns:models="using:StudentDesktop.Models"
             xmlns:avconv="using:Avalonia.Data.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="StudentDesktop.Views.CoursesView"
             x:DataType="vm:CoursesViewModel">

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="16,12" Spacing="8">
            <TextBlock Text="Courses" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="SDA-18: course &amp; teacher info per enrolled subject. SDA-17: leave feedback about a course's teacher."
                       TextWrapping="Wrap" Foreground="Gray"/>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="IndianRed" TextWrapping="Wrap"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static avconv:StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>

        <Border DockPanel.Dock="Left" Width="280" BorderBrush="#DDDDDD" BorderThickness="0,0,1,0">
            <ListBox ItemsSource="{Binding Courses}" SelectedItem="{Binding SelectedCourse}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="models:CourseInfoDto">
                        <StackPanel Margin="0,4">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Code}" FontSize="11" Foreground="Gray"/>
                            <TextBlock Text="{Binding TeacherName}" FontSize="12"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Margin="24" Spacing="10" MaxWidth="420"
                    IsVisible="{Binding SelectedCourse, Converter={x:Static avconv:ObjectConverters.IsNotNull}}">
            <TextBlock Text="{Binding SelectedCourse.Name}" FontSize="16" FontWeight="Bold"/>
            <TextBlock Text="{Binding SelectedCourse.TeacherName, StringFormat='Teacher: {0}'}"/>

            <TextBlock Text="Leave feedback" FontWeight="Bold" Margin="0,12,0,0"/>
            <TextBlock Text="Rating (1-5)"/>
            <ComboBox SelectedItem="{Binding FeedbackRating}" HorizontalAlignment="Stretch">
                <ComboBox.Items>
                    <x:Int32>1</x:Int32>
                    <x:Int32>2</x:Int32>
                    <x:Int32>3</x:Int32>
                    <x:Int32>4</x:Int32>
                    <x:Int32>5</x:Int32>
                </ComboBox.Items>
            </ComboBox>
            <TextBlock Text="Comments (optional)"/>
            <TextBox Text="{Binding FeedbackComments}" AcceptsReturn="True" TextWrapping="Wrap" Height="100"/>
            <Button Content="Submit feedback" Command="{Binding SubmitFeedbackCommand}"/>
            <TextBlock Text="{Binding FeedbackMessage}" Foreground="Green"
                       IsVisible="{Binding FeedbackMessage, Converter={x:Static avconv:StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>
    </DockPanel>

</UserControl>
