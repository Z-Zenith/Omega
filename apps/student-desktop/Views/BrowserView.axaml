<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StudentDesktop.ViewModels"
             xmlns:models="using:StudentDesktop.Models"
             xmlns:webview="using:Avalonia.Controls"
             xmlns:avconv="using:Avalonia.Data.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="650"
             x:Class="StudentDesktop.Views.BrowserView"
             x:DataType="vm:BrowserViewModel">

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="16,12" Spacing="8">
            <TextBlock Text="Whitelisted Browser" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Only sites your institution has whitelisted (SDA-03/SDA-04) can be opened here."
                       TextWrapping="Wrap" Foreground="Gray"/>
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBox Grid.Column="0" Text="{Binding UrlInput}" PlaceholderText="https://example.com"/>
                <Button Grid.Column="1" Content="Go" Command="{Binding NavigateCommand}" Margin="8,0,0,0"/>
                <Button Grid.Column="2" Content="Clip to Notes" Command="{Binding OpenClipPanelCommand}" Margin="8,0,0,0"/>
            </Grid>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="IndianRed" TextWrapping="Wrap"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static avconv:StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>

        <Border DockPanel.Dock="Right" Width="360" BorderBrush="#DDDDDD" BorderThickness="1,0,0,0" Padding="16"
                IsVisible="{Binding IsClipPanelOpen}">
            <ScrollViewer>
                <StackPanel Spacing="10">
                    <TextBlock Text="Clip to Notes" FontSize="16" FontWeight="Bold"/>

                    <RadioButton Content="New note" IsChecked="{Binding IsNewNote}" GroupName="ClipMode"/>
                    <RadioButton Content="Append to existing note" IsChecked="{Binding !IsNewNote}" GroupName="ClipMode"/>

                    <StackPanel IsVisible="{Binding IsNewNote}" Spacing="4">
                        <TextBlock Text="Note title"/>
                        <TextBox Text="{Binding ClipNoteTitle}"/>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding !IsNewNote}" Spacing="4">
                        <TextBlock Text="Existing note"/>
                        <ComboBox ItemsSource="{Binding ExistingNotes}" SelectedItem="{Binding SelectedExistingNote}" HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="models:NoteSummaryDto">
                                    <TextBlock Text="{Binding Title}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock Text="Content to clip"/>
                    <TextBox Text="{Binding ClipContent}" AcceptsReturn="True" TextWrapping="Wrap" Height="160"/>
                    <TextBlock Text="Pre-filled from your current text selection on the page, if any — edit freely before saving."
                               TextWrapping="Wrap" Foreground="Gray" FontSize="11"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Save" Command="{Binding SaveClipCommand}"/>
                        <Button Content="Cancel" Command="{Binding CloseClipPanelCommand}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding ClipErrorMessage}" Foreground="IndianRed" TextWrapping="Wrap"
                               IsVisible="{Binding ClipErrorMessage, Converter={x:Static avconv:StringConverters.IsNotNullOrEmpty}}"/>
                    <TextBlock Text="{Binding ClipSuccessMessage}" Foreground="Green" TextWrapping="Wrap"
                               IsVisible="{Binding ClipSuccessMessage, Converter={x:Static avconv:StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <webview:NativeWebView x:Name="WebViewControl" Source="{Binding CurrentSource}"/>
    </DockPanel>

</UserControl>
