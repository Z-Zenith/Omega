<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StudentDesktop.ViewModels"
             xmlns:models="using:StudentDesktop.Models"
             xmlns:avconv="using:Avalonia.Data.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="650"
             x:Class="StudentDesktop.Views.CommunityView"
             x:DataType="vm:CommunityViewModel">

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="16,12" Spacing="8">
            <TextBlock Text="Community" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="IndianRed" TextWrapping="Wrap"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static avconv:StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>

        <Border DockPanel.Dock="Left" Width="240" BorderBrush="#DDDDDD" BorderThickness="0,0,1,0">
            <ListBox ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedGroup}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="models:GroupDto">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Type}" FontSize="11" Foreground="Gray"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <ScrollViewer>
            <StackPanel Margin="16" Spacing="16" IsVisible="{Binding SelectedGroup, Converter={x:Static avconv:ObjectConverters.IsNotNull}}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Materials" FontWeight="Bold"/>
                    <ItemsControl ItemsSource="{Binding Materials}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:MaterialDto">
                                <TextBlock Text="{Binding Title}" Margin="0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="Posts" FontWeight="Bold"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0" Text="{Binding NewPostContent}" PlaceholderText="Post something…" AcceptsReturn="True"/>
                        <Button Grid.Column="1" Content="Post" Command="{Binding PostCommand}" Margin="8,0,0,0"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Posts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:GroupPostDto">
                                <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding CreatedAt}" FontSize="11" Foreground="Gray"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>

</UserControl>
