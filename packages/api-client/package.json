{
  "name": "@campus/api-client",
  "version": "0.1.0",
  "private": true,
  "description": "Shared web API client — session-token storage, the fetch wrapper, and the request/response DTOs genuinely common across Teacher Web (TWA), Admin Web (AWA), and Parent Portal (PRT). Extracted per issue #87: this logic was duplicated (byte-identical in the core HTTP client) across all three apps' src/lib/api.ts files.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./http": {
      "types": "./src/http.ts",
      "default": "./src/http.ts"
    },
    "./auth": {
      "types": "./src/auth.ts",
      "default": "./src/auth.ts"
    },
    "./timetable": {
      "types": "./src/timetable.ts",
      "default": "./src/timetable.ts"
    },
    "./events": {
      "types": "./src/events.ts",
      "default": "./src/events.ts"
    },
    "./reports": {
      "types": "./src/reports.ts",
      "default": "./src/reports.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc",
    "build": "tsc -p tsconfig.base.json",
    "test": "tsc && node --test"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "campus-platform",
    "api-client",
    "twa",
    "awa",
    "prt"
  ],
  "license": "UNLICENSED"
}
