{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    // Only for this type-check-only project (never the emitting build config):
    // lets tests/ import ../src/*.ts by its real extension so Node's native
    // TypeScript type-stripping (node --test) can resolve it without a bundler.
    "allowImportingTsExtensions": true
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}

