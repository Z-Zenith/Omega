# Copy to .env and fill in real values. Never commit .env.
#
# JWT signing key for backend-api (services/backend-api). Required for
# `docker compose up backend-api` — the app fails fast at startup without it
# outside Development. Generate one with, e.g.:
#   openssl rand -base64 48
JWT_SIGNING_KEY=

# Postgres superuser password for the main `campus` database (docker-compose.yml
# `postgres` and `backend-api` services). Required — `docker compose up` fails
# fast without it (#137). Dev default used across this repo's docs: campus_dev.
POSTGRES_PASSWORD=campus_dev

# Password for the additive, least-privilege `campus_app` Postgres role created
# by db/init/03_create_app_role.sh (#137). Optional — defaults to campus_app_dev
# for local dev if unset. Rotate before any non-dev deploy. Not currently used
# by backend-api's default connection string (see db/init/03_create_app_role.sh
# for why the cutover is deliberately deferred).
POSTGRES_APP_PASSWORD=campus_app_dev

# Preshared key OpenFGA (services/authz) requires from any caller of its HTTP
# API on the compose network. Required — `docker compose up` fails fast without
# it (#133). Generate one with, e.g.:
#   openssl rand -base64 32
# Clients must send it as `Authorization: Bearer <key>`.
OPENFGA_PRESHARED_KEY=
